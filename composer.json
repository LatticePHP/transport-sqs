{
    "name": "lattice/transport-sqs",
    "description": "AWS SQS transport adapter for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "sqs",
        "aws",
        "transport",
        "messaging",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/transport-sqs"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Transport\\Sqs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Transport\\Sqs\\Tests\\": "tests/"
        }
    }
}
